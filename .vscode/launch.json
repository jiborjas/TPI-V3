{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TPI-V3: STM32F103C8 (ST-Link/OpenOCD)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/firmware/bin/main.elf",
      "device": "STM32F103C8",
      "interface": "swd",
      "runToEntryPoint": "main",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ],
      "preLaunchTask": "TPI-V3: build firmware"
    }
  ]
}
